# ============================================================================
# .env.example — template for local-only secrets (copy to .env.local)
# ============================================================================
#
# How to use:
#   1. cp .env.example .env.local
#   2. Fill in the real values
#   3. .env.local is gitignored (.gitignore rule: *.local) — never commit it
#
# Already-committed .env (in repo root) contains only the PUBLIC anon key
# (VITE_SUPABASE_PUBLISHABLE_KEY) — safe by Supabase design. Do NOT put any
# of the secrets below into .env.
# ============================================================================


# ---------- Supabase MCP (see docs/MCP_SETUP.md) ----------
# Personal Access Token from https://supabase.com/dashboard/account/tokens
# Scope: whole account (all projects). The .mcp.json pins --project-ref so
# queries can't leak to other projects, but the TOKEN ITSELF is account-wide.
# Rotate every 90 days. Revoke immediately if leaked.
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token_here


# ---------- Context7 MCP (optional) ----------
# Without an API key, Context7 runs with a shared rate limit. For heavier
# usage, sign up at https://context7.com and set the key below. Leave empty
# to use the free tier.
# CONTEXT7_API_KEY=ctx7_your_api_key_here
